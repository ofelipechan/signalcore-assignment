{
  "name": "vendor-research-tool",
  "private": true,
  "version": "0.1.0",
  "description": "AI-powered vendor comparison: backend (FastAPI) + frontend (React/Vite)",
  "scripts": {
    "start": "concurrently -n be,fe -c blue,green \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && python -m uvicorn app.main:app --reload --port 8001",
    "start:frontend": "cd frontend && pnpm run dev",
    "start:docker": "docker compose up",
    "install:all": "pnpm i && npm run install:backend && npm run install:frontend",
    "install:backend": "cd backend && python -m pip install -r ../requirements.txt",
    "install:frontend": "cd frontend && pnpm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
