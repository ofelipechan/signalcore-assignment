# ---------------------------------------------------------------------------
# Vendor Research Tool — copy to .env and fill in your API keys
# ---------------------------------------------------------------------------

# --- LLM (set at least one for the provider you use) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=

# --- Search (required for web search) ---
TAVILY_API_KEY=

# --- Default model when request does not specify provider/model ---
DEFAULT_LLM_PROVIDER=
DEFAULT_LLM_MODEL=

# Examples for other providers:
# DEFAULT_LLM_PROVIDER=anthropic
# DEFAULT_LLM_MODEL=claude-3-5-sonnet-20241022
# DEFAULT_LLM_PROVIDER=openrouter
# DEFAULT_LLM_MODEL=openai/gpt-4o

# --- Optional ---
# PORT=8000
# MAX_AGENT_STEPS=8
# HTTP_TIMEOUT_SECONDS=30.0